---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'BBS — Stands that Stands !!',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
  subtitle='Empowering Every Transaction with Style and Security. Business Based Solutions: Where Your Brand Meets Innovation.'
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'AstroWind Hero Image' }}
  >
    <Fragment slot="title">
     Business Based Solutions
    </Fragment>

  </Hero>

  <!-- Note Widget ******************* -->


  <!-- Features Widget *************** -->



  <!-- Content Widget **************** -->

  <Brands
    title="Some of our clients"
    subtitle="At BBS, we believe in the power of collaboration to drive innovation and create exceptional experiences."
    icons={[]}
    images={[
      {
        src: '~/assets/images/logos/pmi.png',
        alt: 'PMI',
      },
      {
        src: '~/assets/images/logos/arabbank.jpg',
        alt: 'Arab Bank',
      },
      {
        src: '~/assets/images/logos/bop.jpg',
        alt: 'Bank of Palestine',
      },
      {
        src: '~/assets/images/logos/apic.png',
        alt: 'APIC',
      },

      {
        src: '~/assets/images/logos/popeyes.png',
        alt: 'Popeyes',
      }
    ]}
  />

  <!-- Content Widget **************** -->

</Layout>
